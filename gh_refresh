#!/usr/bin/env bash
# Fetch fresh data from LoTW + QRZ and deploy to GitHub Pages only.
#
# Usage:
#   ./gh_refresh          # incremental LoTW + QRZ fetch
#   ./gh_refresh --full   # re-download everything from scratch
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"

FULL=""
if [[ "${1:-}" == "--full" ]]; then
    FULL="--full"
fi

echo "=== Step 1/3: Fetch LoTW data ${FULL:-(incremental)} ==="
"${DIR}/lotw_fetch" ${FULL}

echo ""
echo "=== Step 2/3: Fetch QRZ enrichment ${FULL:-(incremental)} ==="
"${DIR}/qrz_fetch" ${FULL}

echo ""
echo "=== Step 3/3: Deploy to GitHub Pages ==="
"${DIR}/gh_pages_deploy"

echo ""
echo "=== Done. https://gvrocha.github.io/contact_mapping/ is live. ==="
